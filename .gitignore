# ==================
# Xcode
# ==================

# Build artifacts
build/
DerivedData/
*.o
*.hmap

# User-specific Xcode files
*.xcuserstate
*.xcworkspace/xcuserdata/
xcuserdata/

# Xcode Scheme files (keep shared schemes, ignore user-specific ones)
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/

# Playground intermediates
timeline.xctimeline
playground.xcworkspace

# ==================
# Swift Package Manager
# ==================

.build/
.swiftpm/
*.resolved

# Uncomment to ignore Package.resolved (not recommended for apps)
# Package.resolved

# ==================
# CocoaPods
# ==================

Pods/
*.xcworkspace
!default.xcworkspace

# Podfile.lock should be committed for apps, not libraries
# Uncomment the line below if this is a library:
# Podfile.lock

